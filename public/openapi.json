  },
  "components": {
    "schemas": {
      "Character": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique character identifier",
            "example": "ayaka"
          },
          "index": {
            "type": "number",
            "description": "Character index/order"
          },
          "name": {
            "type": "string",
            "description": "Character display name",
            "example": "Ayaka"
          },
          "key": {
            "type": "string",
            "description": "Character key identifier",
            "example": "ayaka"
          },
          "title": {
            "type": "string",
            "description": "Character title",
            "example": "Frostflake Heron"
          },
          "rarity": {
            "type": "number",
            "description": "Character rarity (4-5 stars)",
            "example": 5,
            "minimum": 4,
            "maximum": 5
          },
          "element": {
            "type": "string",
            "description": "Character element",
            "example": "Cryo"
          },
          "vision": {
            "type": "string",
            "description": "Character vision (same as element)",
            "example": "Cryo"
          },
          "weapon": {
            "type": "string",
            "description": "Character weapon type",
            "example": "Sword"
          },
          "release_date": {
            "type": "string",
            "description": "Character release date",
            "example": "2021-07-21"
          },
          "release_date_epoch": {
            "type": "number",
            "description": "Release date as Unix timestamp",
            "example": 1626825600
          },
          "constellation": {
            "type": "string",
            "description": "Character constellation name",
            "example": "Grus Nivis"
          },
          "birthday": {
            "type": "string",
            "description": "Character birthday (MM-DD)",
            "example": "09-28"
          },
          "affiliation": {
            "type": "string",
            "description": "Character affiliation/group",
            "example": "Yashiro Commission"
          },
          "region": {
            "type": "string",
            "description": "Character region",
            "example": "Inazuma"
          },
          "special_dish": {
            "type": "string",
            "description": "Character special dish",
            "example": "Snow on the Hearth"
          },
          "alternate_title": {
            "type": "string",
            "description": "Alternate character title"
          },
          "description": {
            "type": "string",
            "description": "Character description"
          },
          "ascension_stat": {
            "type": "string",
            "description": "Character ascension stat bonus",
            "example": "CRIT_DMG"
          },
          "base_stats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterBaseStat"
            }
          },
          "ascension_costs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterAscensionCost"
            }
          },
          "talents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterTalent"
            }
          },
          "passives": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterPassive"
            }
          },
          "constellations": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterConstellation"
            }
          }
        },
        "required": [
          "id",
          "name",
          "key",
          "title",
          "rarity",
          "element",
          "vision",
          "weapon",
          "release_date",
          "release_date_epoch",
          "constellation",
          "birthday",
          "affiliation",
          "region",
          "special_dish",
          "description",
          "ascension_stat",
          "base_stats",
          "ascension_costs",
          "talents",
          "passives",
          "constellations"
        ]
      },
      "CharacterBaseStat": {
        "type": "object",
        "properties": {
          "LVL": {
            "type": "string",
            "description": "Character level"
          },
          "BaseHP": {
            "type": "string",
            "description": "Base HP value"
          },
          "BaseATK": {
            "type": "string",
            "description": "Base ATK value"
          },
          "BaseDEF": {
            "type": "string",
            "description": "Base DEF value"
          },
          "AscensionStatType": {
            "type": "string",
            "description": "Type of ascension stat bonus"
          },
          "AscensionStatValue": {
            "type": "string",
            "description": "Value of ascension stat bonus"
          },
          "AscensionPhase": {
            "type": "number",
            "description": "Ascension phase level"
          }
        },
        "required": [
          "LVL",
          "BaseHP",
          "BaseATK",
          "BaseDEF",
          "AscensionStatType",
          "AscensionStatValue",
          "AscensionPhase"
        ]
      },
      "CharacterTalent": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Talent name"
          },
          "type": {
            "type": "string",
            "description": "Talent type"
          },
          "description": {
            "type": "string",
            "description": "Talent description"
          },
          "attributes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterTalentAttribute"
            }
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "any"
            }
          }
        },
        "required": [
          "name",
          "type",
          "description",
          "properties"
        ]
      },
      "CharacterTalentAttribute": {
        "type": "object",
        "properties": {
          "hit": {
            "type": "string",
            "description": "Hit type or condition"
          },
          "values": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "number"
                },
                {
                  "type": "string"
                }
              ]
            },
            "description": "Array of talent values for different levels"
          }
        },
        "required": [
          "hit",
          "values"
        ]
      },
      "CharacterPassive": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Passive talent name"
          },
          "type": {
            "type": "string",
            "description": "Passive type"
          },
          "description": {
            "type": "string",
            "description": "Passive talent description"
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "any"
            }
          }
        },
        "required": [
          "name",
          "type",
          "description"
        ]
      },
      "CharacterConstellation": {
        "type": "object",
        "properties": {
          "level": {
            "type": "number",
            "description": "Constellation level"
          },
          "name": {
            "type": "string",
            "description": "Constellation name"
          },
          "description": {
            "type": "string",
            "description": "Constellation effect description"
          },
          "properties": {
            "type": "array",
            "items": {
              "type": "any"
            }
          }
        },
        "required": [
          "level",
          "name",
          "description",
          "properties"
        ]
      },
      "CharacterAscensionCost": {
        "type": "object",
        "properties": {
          "AscensionPhase": {
            "type": "number",
            "description": "Ascension phase number"
          },
          "materials": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CharacterAscensionMaterial"
            }
          }
        },
        "required": [
          "AscensionPhase",
          "materials"
        ]
      },
      "CharacterAscensionMaterial": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Material name"
          },
          "amount": {
            "type": "string",
            "description": "Required amount"
          }
        },
        "required": [
          "name",
          "amount"
        ]
      },
      "Weapon": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique weapon identifier"
          },
          "name": {
            "type": "string",
            "description": "Weapon display name"
          },
          "key": {
            "type": "string",
            "description": "Weapon key identifier"
          },
          "rarity": {
            "type": "number",
            "description": "Weapon rarity (1-5 stars)"
          },
          "description": {
            "type": "string",
            "description": "Weapon description"
          },
          "category": {
            "type": "string",
            "description": "Weapon category"
          },
          "series": {
            "type": "string",
            "description": "Weapon series"
          },
          "release_date": {
            "type": "string",
            "description": "Weapon release date"
          },
          "release_date_epoch": {
            "type": "number",
            "description": "Release date as Unix timestamp"
          },
          "base_atk_min": {
            "type": "number",
            "description": "Minimum base attack"
          },
          "base_atk_max": {
            "type": "number",
            "description": "Maximum base attack"
          },
          "sub_stat_type": {
            "type": "string",
            "description": "Sub stat type"
          },
          "sub_stat_value_min": {
            "type": "string",
            "description": "Minimum sub stat value"
          },
          "sub_stat_value_max": {
            "type": "string",
            "description": "Maximum sub stat value"
          },
          "refinement_name": {
            "type": "string",
            "description": "Refinement effect name"
          },
          "refinements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Refinement descriptions"
          },
          "base_stats": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/WeaponBaseStat"
            }
          }
        },
        "required": [
          "id",
          "name",
          "key",
          "rarity",
          "description",
          "category",
          "series",
          "release_date",
          "release_date_epoch",
          "base_atk_min",
          "base_atk_max",
          "sub_stat_type",
          "sub_stat_value_min",
          "sub_stat_value_max",
          "refinement_name",
          "refinements",
          "base_stats"
        ]
      },
      "WeaponBaseStat": {
        "type": "object",
        "properties": {
          "level": {
            "type": "string",
            "description": "Weapon level"
          },
          "base_atk": {
            "type": "string",
            "description": "Base attack at this level"
          },
          "sub_stat_type": {
            "type": "string",
            "description": "Sub stat type"
          },
          "sub_stat_value": {
            "type": "string",
            "description": "Sub stat value"
          },
          "ascension_phase": {
            "type": "number",
            "description": "Ascension phase"
          }
        },
        "required": [
          "level",
          "base_atk"
        ]
      },
      "Artifact": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique artifact identifier"
          },
          "name": {
            "type": "string",
            "description": "Artifact set name"
          },
          "key": {
            "type": "string",
            "description": "Artifact key identifier"
          },
          "rarity_max": {
            "type": "number",
            "description": "Maximum rarity"
          },
          "rarity_min": {
            "type": "number",
            "description": "Minimum rarity"
          },
          "release_version": {
            "type": "string",
            "description": "Release version"
          },
          "flower_description": {
            "type": "string",
            "description": "Flower piece description"
          },
          "feather_description": {
            "type": "string",
            "description": "Feather piece description"
          },
          "sand_description": {
            "type": "string",
            "description": "Sand piece description"
          },
