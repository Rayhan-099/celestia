        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Artifact ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Artifact data",
            "content": {
